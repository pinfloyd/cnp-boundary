{"added_lines":["AUTHORITY_URL=http://107.172.34.21:8787","","AUTHORITY_URL=http://107.172.34.21:8787",".github/workflows/* @pinfloyd",".authority/* @pinfloyd","run-name: authority-enforcement_${{ github.run_number }}_${{ github.run_attempt }}","        with:","          fetch-depth: 2","        shell: bash","          set -euo pipefail","          URL=$(cat .authority/endpoint.lock | cut -d= -f2)","          echo \"AUTHORITY_URL=$URL\"","          curl -fsS \"$URL/pubkey\" >/dev/null","      - name: Generate canonical intent-v1","        shell: bash","          set -euo pipefail","          python3 - <<'PY'","          import hashlib","          import json","          import os","          import subprocess","          from pathlib import Path","","          event_name = os.environ.get(\"GITHUB_EVENT_NAME\", \"\")","          repo = os.environ.get(\"GITHUB_REPOSITORY\", \"\")","          ref = os.environ.get(\"GITHUB_REF\", \"\")","          schema = \"intent-v1\"","          policy_id = \"ai-secrets-v1\"","","          added = []","","          if event_name == \"pull_request\":","              parent_line = subprocess.check_output([\"git\", \"rev-list\", \"--parents\", \"-n\", \"1\", \"HEAD\"], text=True).strip().split()","              parent_count = max(len(parent_line) - 1, 0)","              if parent_count < 2:","                  raise SystemExit(\"MERGE_COMMIT_REQUIRED\")","              diff_text = subprocess.check_output([\"git\", \"diff\", \"--unified=0\", \"HEAD^1\", \"HEAD\", \"--\"], text=True, encoding=\"utf-8\", errors=\"strict\")","              for line in diff_text.splitlines():","                  if line.startswith(\"+++ \"):","                      continue","                  if line.startswith(\"@@\"):","                      continue","                  if line.startswith(\"+\"):","                      added.append(line[1:])","          elif event_name == \"workflow_dispatch\":","              added = [","                  \"AUTHORITY_ENFORCEMENT_WORKFLOW_DISPATCH=1\",","                  f\"REPO={repo}\",","                  f\"REF={ref}\",","                  f\"SHA={os.environ.get('GITHUB_SHA', '')}\",","                  \"SCHEMA=intent-v1\",","                  \"POLICY_ID=ai-secrets-v1\"","              ]","          else:","              raise SystemExit(\"ONLY_PULL_REQUEST_OR_WORKFLOW_DISPATCH_SUPPORTED\")","","          joined = \"\\n\".join(added)","          added_lines_sha256 = hashlib.sha256(joined.encode(\"utf-8\")).hexdigest()","","          intent = {","              \"added_lines\": added,","              \"added_lines_sha256\": added_lines_sha256,","              \"policy_id\": policy_id,","              \"ref\": ref,","              \"repo\": repo,","              \"schema\": schema","          }","","          text = json.dumps(intent, ensure_ascii=False, separators=(\",\", \":\"))","          Path(\"intent_v1.json\").write_text(text, encoding=\"utf-8\")","","          raw = Path(\"intent_v1.json\").read_bytes()","          parsed = json.loads(raw.decode(\"utf-8\"))","","          print(\"INTENT_PATH=intent_v1.json\")","          print(f\"EVENT_NAME={event_name}\")","          print(\"ADDED_LINES_TYPE=list\")","          print(f\"ADDED_LINES_COUNT={len(added)}\")","          print(f\"ADDED_LINES_JOINED_SHA256={added_lines_sha256}\")","          print(f\"INTENT_BYTES_LEN={len(raw)}\")","          print(f\"INTENT_BYTES_SHA256={hashlib.sha256(raw).hexdigest()}\")","          print(f\"INTENT_UTF8_JSON_LOADS_OK={'yes' if parsed == intent else 'no'}\")","          PY","          echo \"INTENT_JSON_BEGIN\"","          cat intent_v1.json","          echo","          echo \"INTENT_JSON_END\"","","      - name: Submit canonical intent-v1 to authority","        shell: bash","        run: |","          set -euo pipefail","          URL=$(cat .authority/endpoint.lock | cut -d= -f2)","          HTTP_CODE=$(curl --trace-ascii admit.trace.txt -sS -D admit.headers.txt -o admit_response.txt -w \"%{http_code}\" -X POST \"$URL/admit\" -H \"content-type: application/json\" --data-binary @intent_v1.json)","          echo \"ADMIT_HTTP_CODE=$HTTP_CODE\"","          echo \"ADMIT_HEADERS_BEGIN\"","          cat admit.headers.txt || true","          echo","          echo \"ADMIT_HEADERS_END\"","          echo \"ADMIT_RESPONSE_BEGIN\"","          cat admit_response.txt || true","          echo","          echo \"ADMIT_RESPONSE_END\"","          echo \"ADMIT_TRACE_BEGIN\"","          cat admit.trace.txt || true","          echo","          echo \"ADMIT_TRACE_END\"","          DECISION=$(python3 - <<'PY'","          import json","          from pathlib import Path","          obj = json.loads(Path(\"admit_response.txt\").read_text(encoding=\"utf-8\"))","          print(obj.get(\"record\", {}).get(\"decision\", \"\"))","          PY","          )","          echo \"ADMIT_DECISION=$DECISION\"","          if [ \"$HTTP_CODE\" -ge 400 ]; then","            echo \"ADMISSION_FAIL_CLOSED\"","            exit 1","          fi","          if [ \"$DECISION\" != \"ALLOW\" ]; then","            echo \"ADMISSION_FAIL_CLOSED\"","            exit 1","          fi","","# tamper test","HARMLESS_PR_PROOF=1","TYPE=HARMLESS","REPO=pinfloyd/ai-action-firewall-client-v1","BASE_BRANCH=main","TEST_BRANCH=proof-harmless-pr-20260309_134250Z","STEP=S73_NEW_HARMLESS_PR_SYNCHRONIZE_TEST_PUSH_WAIT_LOGS","RUN_UTC=20260309_153053Z","","HARMLESS_PR_PROOF=1","TYPE=HARMLESS","REPO=pinfloyd/ai-action-firewall-client-v1","BASE_BRANCH=main","TEST_BRANCH=proof-harmless-pr-20260309_161922Z","STEP=S76_NEW_HARMLESS_PR_FROM_PROVEN_STATE_PUSH_WAIT_LOGS","RUN_UTC=20260309_161922Z",""],"added_lines_sha256":"b3b505fd03223c54484425fed6a202da763c4e431de027735eaec0533889ee24","policy_id":"ai-secrets-v1","ref":"refs/pull/12/merge","repo":"pinfloyd/ai-action-firewall-client-v1","schema":"intent-v1"}